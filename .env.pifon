# Local / dev: use with ./up pifon (binds 127.0.0.1:8080, 127.0.0.1:8443)
# Set APP_KEY (e.g. copy from existing .env or run: php artisan key:generate --show).
APP_NAME=RCP
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://pifon

DB_CONNECTION=mysql
DB_HOST=database
DB_PORT=3306
DB_DATABASE=rcp_api
DB_USERNAME=root
DB_PASSWORD=

MARIADB_ROOT_PASSWORD=

# Local: bind to loopback only
API_BIND=127.0.0.1
API_HTTP_PORT=8080
API_HTTPS_PORT=8443
